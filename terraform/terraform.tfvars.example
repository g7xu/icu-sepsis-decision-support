# Copy this file to terraform.tfvars and fill in your values
# terraform.tfvars is gitignored by default

aws_region = "us-east-1"

db_name     = "mimiciv"
db_username = "postgres"
db_password = "CHANGE_ME_TO_STRONG_PASSWORD"  # Use a strong password!

# Instance configuration
db_instance_class      = "db.t4g.micro"   # Sufficient for cached queries; free tier eligible
db_allocated_storage   = 20               # Initial storage in GB
max_allocated_storage  = 30               # Sufficient for app tables subset
db_storage_type        = "gp2"
db_engine_version      = "15.14"

# Backup settings
backup_retention_period = 7
skip_final_snapshot     = true  # Set to false for production

# Network settings
publicly_accessible = true
# Restrict access to your IP: replace with your IP (e.g. ["1.2.3.4/32"])
allowed_cidr_blocks = ["0.0.0.0/0"]  # WARNING: Change this to your IP!

# Project settings
environment  = "dev"
project_name = "icu-sepsis"

# ── EC2 Settings ──────────────────────────────────────────────

ec2_instance_type = "t3.small"
# ec2_ami_id      = ""  # Leave empty to auto-lookup latest Amazon Linux 2023

# Restrict SSH access to your IP (recommended)
ssh_allowed_cidr_blocks = ["0.0.0.0/0"]  # WARNING: Change to your IP, e.g. ["1.2.3.4/32"]

# ── App / Django Settings ─────────────────────────────────────

django_secret_key = "CHANGE_ME_TO_RANDOM_SECRET_KEY"  # Use: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# Domain (set up DNS in Cloudflare pointing to the Elastic IP after terraform apply)
domain_name = "your-domain.example.com"

# ML model service (leave empty for stub mode)
model_service_url = ""
model_s3_bucket   = ""

# ── Deployment ────────────────────────────────────────────────
# After `terraform apply`, push your Docker image to ECR then deploy:
#   ./deploy.sh              # Build, push to ECR, and deploy to EC2
#   ./deploy.sh --build-only # Build and push only (no SSH deploy)
