# Copy this file to .env and fill in your values
# cp .env.example .env

# ===========================================
# Database Configuration
# ===========================================
# Choose ONE: Docker with RDS (recommended) OR Docker with local DB OR local Django.

# --- Docker with AWS RDS (recommended for this app) ---
# Use this when you run: docker compose up
# Web container will connect to RDS. Get DB_HOST from: cd terraform && terraform output -raw db_address
# Add DB_PASSWORD manually (Terraform cannot output it).
# DB_NAME=mimiciv
# DB_USER=postgres
# DB_PASSWORD=<from terraform.tfvars>
# DB_HOST=<terraform output -raw db_address>
# DB_PORT=5432
# DB_SCHEMA=mimiciv_derived

# --- Docker with local Postgres only ---
# Use only if you have loaded MIMIC + run view scripts on the local db container.
# DB_NAME=sepsis
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=db
# DB_PORT=5432
# DB_SCHEMA=public

# --- Local Django (no Docker), Postgres on this machine ---
# DB_NAME=mimiciv
# DB_USER=postgres
# DB_PASSWORD=your_password_here
# DB_HOST=localhost
# DB_PORT=5432
# DB_SCHEMA=mimiciv_derived

# ===========================================
# Django Settings (optional)
# ===========================================

# SECRET_KEY — generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# SECRET_KEY=your-secret-key-here

# Debug (set to False in production)
# DEBUG=True

# Allowed hosts (comma-separated, no spaces)
# ALLOWED_HOSTS=localhost,127.0.0.1

# Trusted CSRF origins — required for HTTPS deployments behind a proxy (Nginx + Cloudflare).
# Must use full scheme+domain. Comma-separated.
# CSRF_TRUSTED_ORIGINS=https://your-domain.example.com,http://localhost

# Demo mode: enables /demo/patients/ with per-session simulation clock
# When false, only production views at /patients/ are available (no clock)
# DEMO_MODE=false

# ===========================================
# Terraform Secrets (used by deploy.sh and terraform)
# ===========================================
# Source this file before running terraform or ./deploy.sh:
#   set -a && source .env && set +a
#
# TF_VAR_db_password=your-strong-db-password
# TF_VAR_django_secret_key=your-random-django-secret-key

# ===========================================
# Application Settings (optional)
# ===========================================

# In-process joblib model: directory containing sepsis_rf_pipeline.joblib and feature_cols.joblib
# Default: patients/model_artifacts. Leave unset or place files to use real predictions; otherwise stub is used.
# MODEL_ARTIFACTS_DIR=patients/model_artifacts
