# ===========================================
# Database Configuration
# ===========================================

# Default: LOCAL PostgreSQL (matches docker-compose)
DB_NAME=sepsis
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
DB_SCHEMA=public

# For AWS RDS (after running terraform apply):
# Get these values with: cd terraform && terraform output
# Or auto-generate: terraform output -raw env_file_content > ../.env
#
# DB_NAME=mimiciv
# DB_USER=postgres
# DB_PASSWORD=<from terraform.tfvars>
# DB_HOST=<from terraform output db_address>
# DB_PORT=5432
# DB_SCHEMA=mimiciv_derived

# ===========================================
# Django Settings
# ===========================================

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=dev_secret_key

# Set to False in production
DEBUG=True

# Comma-separated, no spaces
ALLOWED_HOSTS=localhost,127.0.0.1

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# ===========================================
# Model Service (external HTTPS prediction API)
# ===========================================

# REQUIRED: Set MODEL_SERVICE_URL to enable predictions. Predictions will not work if empty.
MODEL_SERVICE_URL=
MODEL_SERVICE_TIMEOUT=30
# MODEL_SERVICE_API_KEY=your_api_key_if_required

# History window (hours) included in the model payload.
MODEL_HISTORY_HOURS=6